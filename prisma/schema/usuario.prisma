model usuario {
  id                   Int       @id @default(autoincrement())
  id_supabase          String    @unique @db.Uuid
  nombre               String
  url_foto             String?
  peso                 Decimal?  @db.Decimal
  talla                Decimal?  @db.Decimal
  fecha_nacimiento     DateTime? @db.Date
  nivel_actividad      Int?      @default(1)
  informacion_medica   Json?
  alimentos_prohibidos String[]
  preferencias         String[]
  created_at           DateTime  @default(now()) @db.Timestamptz
  // Relaciones
  // 1 - N
  comidas              comida[]
}
